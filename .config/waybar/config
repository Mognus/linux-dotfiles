{
    "layer": "top",
    "position": "top",
    "height": 36,

    "modules-left": ["clock", "wireplumber"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["group/scratchpads"],

    "clock": {
        "format": "{:%H:%M  %d.%m.%Y}"
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "on-click": "pavucontrol",
        "format-icons": ["󰕿", "󰖀", "󰕾"]
    },

    "hyprland/workspaces": {
        "format": "{icon} {name}",
        "on-click": "activate",
        "sort-by-id": true,
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5]
        },
        "show-special": false,
        "format-icons": {
            "code":  "\uf121",
            "test":  "\uf0c3",
            "flow":  "\uf001",
            "ai":    "\uf0eb",
            "term":  "\uf120"
        }
    },

    "group/scratchpads": {
        "orientation": "horizontal",
        "modules": ["custom/music-scratchpad", "custom/obsidian-scratchpad", "custom/discord-scratchpad", "custom/firefox-scratchpad"]
    },

    "custom/discord-scratchpad": {
        "exec": "~/.config/waybar/scripts/discord-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 9
    },

    "custom/firefox-scratchpad": {
        "exec": "~/.config/waybar/scripts/firefox-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 8
    },

    "custom/cmus-scratchpad": {
        "exec": "~/.config/waybar/scripts/cmus-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 12
    },

    "custom/music-scratchpad": {
        "exec": "~/.config/waybar/scripts/music-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 11
    },

    "custom/obsidian-scratchpad": {
        "exec": "~/.config/waybar/scripts/obsidian-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 10
    }
}
