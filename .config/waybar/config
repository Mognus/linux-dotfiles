{
    "layer": "top",
    "position": "top",
    "height": 60,

    "modules-left": ["group/utilities"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["group/scratchpads"],

    "clock": {
        "format": "{:%H:%M  %d.%m.%Y}"
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "on-click": "pavucontrol",
        "format-icons": ["󰕿", "󰖀", "󰕾"]
    },

    "custom/record": {
        "exec": "~/.config/waybar/scripts/record-status.sh",
        "return-type": "json",
        "interval": 1
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "sort-by-id": true,
        "persistent-workspaces": {
            "*": [1, 2, 3, 4]
        },
        "show-special": false,
        "format-icons": {
            "CODE":  "\uf121",
            "TEST":  "\uf0c3",
            "FLOW":  "\uf001",
            "EXTRA": "\uf0eb"
        }
    },

    "group/utilities": {
        "orientation": "horizontal",
        "modules": ["clock", "wireplumber", "custom/record"]
    },

    "group/scratchpads": {
        "orientation": "horizontal",
        "modules": ["custom/term-scratchpad", "custom/music-scratchpad", "custom/obsidian-scratchpad", "custom/discord-scratchpad", "custom/firefox-scratchpad"]
    },

    "custom/discord-scratchpad": {
        "exec": "~/.config/waybar/scripts/discord-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 9
    },

    "custom/firefox-scratchpad": {
        "exec": "~/.config/waybar/scripts/firefox-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 8
    },

    "custom/cmus-scratchpad": {
        "exec": "~/.config/waybar/scripts/cmus-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 12
    },

    "custom/term-scratchpad": {
        "exec": "~/.config/waybar/scripts/term-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 13
    },

    "custom/music-scratchpad": {
        "exec": "~/.config/waybar/scripts/music-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 11
    },

    "custom/obsidian-scratchpad": {
        "exec": "~/.config/waybar/scripts/obsidian-scratchpad.sh",
        "return-type": "json",
        "interval": "once",
        "signal": 10
    }
}
